# ─── SmartFlow Nexus — Frontend Environment Variables ────────────────────────
# Copy this to .env.local and fill in your keys

# ── Gemini API Key (AI traffic insights, speed recommendations, emergency AI) ──
# FREE — no billing, no credit card
# Get it: https://aistudio.google.com/app/apikey  (click "Create API Key")
# Free tier: 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenRouteService API Key (real road routing & directions) ─────────────────
# FREE — no billing, no credit card  
# Get it: https://openrouteservice.org/dev/#/signup  (email signup only)
# Free tier: 2000 requests/day
# Leave blank to use straight-line fallback (still works for demo!)
NEXT_PUBLIC_ORS_API_KEY=your_ors_api_key_here

# ── Backend API URL ───────────────────────────────────────────────────────────
# Keep as-is for local development
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# ZERO COST MAP STACK:
#   Map tiles  → OpenStreetMap    (free, no key needed)
#   Satellite  → Esri Imagery     (free, no key needed)  
#   Geocoding  → Nominatim/OSM    (free, no key needed)
#   Routing    → OpenRouteService (free with key above)
#   AI Flows   → Google Gemini    (free with key above)
# ─────────────────────────────────────────────────────────────────────────────
