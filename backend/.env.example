# ─── SmartFlow Nexus Backend — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your real keys

# OpenAI API Key (required for CrewAI agents with gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Use a different model (default: openai/gpt-4o-mini)
# CREWAI_MODEL=openai/gpt-4o

# Backend server settings
HOST=0.0.0.0
PORT=8000
